{
  // MongoDB database connection info
  "ConnectionStrings": {
    "DefaultConnectionString": "mongodb://localhost:27017"
  },
  "TravlrDatabase": {
    "ConnectionString": "mongodb://localhost:27017",
    "DatabaseName": "travlr",
    "TripsCollectionName": "trips",
    "UsersCollectionName": "users"
  },
  "JwtSettings": {
    "Issuer": "Travlr.WebApi",
    "Audience": "Travlr.AppAdmin",
    "ExpiryMinutes": 60
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
